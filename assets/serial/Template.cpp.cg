#include "{{header_path}}"

namespace serial {
	{% for version in versions %}
	namespace {{version.namespace_str}} {
		{% for e in version.enums %}
		/**** {{e.name}} ****/

		const char *{{e.name}}_str({{e.name}} val) {
			switch (val) {
				{% for enumerator in e.enumerators %}
				case {{e.name}}::{{enumerator.name}}:
					return "{{enumerator.name}}";
				{% endfor %}
				default:
					return "_UNKNOWN_";
			}
		};
		{% endfor %}

		{% for b in version.bitfields %}
		/**** {{b.name}} ****/

		std::ostream &print_{{b.name}}(std::ostream &os, {{b.name}} const &val) {
			const char *frag = "";
			{% for f in b.fields %}
			if (val.{{f.name}}) {
				os << frag << "{{f.name}}";
				frag = " | ";
			}
			{% endfor %}
			return os;
		};
		{% endfor %}

		{% for s in version.structs %}
		/**** Transactions for {{s.name}} ****/
		{% for f in s.fields %}
		{% if f.is_optional %}
		bool {{s.name}}::has_{{f.name}}() const {
			return _{{f.name}}.has_value();
		}
		{% endif %}
		{% if f.is_primitive %}
		{{s.name}}::{{f.set_trans_name}}::{{f.set_trans_name}}({{f.type_str}} value): _value(value) {}

		Transaction::Ptr {{s.name}}::{{f.set_trans_name}}::create({{f.type_str}} value) {
			return Ptr(new {{f.set_trans_name}}(value));
		}

		Transaction::Ptr {{s.name}}::{{f.set_trans_name}}::apply(Object &obj) {
			log_assert(
				obj.type_id() == TYPE_ID,
				util::f("Expecting object of type {{f.type_str}} but got ", obj.type_str())
			);

			{{s.name}} &cast_obj = static_cast<{{s.name}}&>(obj);
			cast_obj._ignore_start();
			auto old_value = cast_obj.{{f.name}}();
			cast_obj.set_{{f.name}}(_value);
			cast_obj._ignore_end();

			return {{f.set_trans_name}}::create(old_value);
		}
		{% else %}
		{{s.name}}::{{f.mod_trans_name}}::{{f.mod_trans_name}}(Transaction::Ptr &&child_t): _child_t(std::move(child_t)) {}

		Transaction::Ptr {{s.name}}::{{f.mod_trans_name}}::create(Transaction::Ptr &&child_t) {
			return Ptr(new {{f.mod_trans_name}}(std::move(child_t)));
		}

		Transaction::Ptr {{s.name}}::{{f.mod_trans_name}}::apply(Object &obj) {
			log_assert(
				obj.type_id() == TYPE_ID,
				util::f("Expecting object of type {{f.type_str}} but got ", obj.type_str())
			);

			{{s.name}} &cast_obj = static_cast<{{s.name}}&>(obj);
			cast_obj._ignore_start();
			{% if f.is_optional %}
			log_assert(cast_obj._{{f.name}}.has_value(), "Must call has_{{f.name}} before accessing {{f.name}}");
			//auto t = {{f.mod_trans_name}}::create(_child_t->apply(cast_obj._{{f.name}}.value()));
			{% else %}
			//auto t = {{f.mod_trans_name}}::create(_child_t->apply(cast_obj._{{f.name}}));
			{% endif %}
			cast_obj._ignore_end();

			//return t;
			return nullptr;
		}
		{% endif %}

		{% endfor %}

		uint32_t {{s.name}}::type_id() const {
			return TYPE_ID;
		}

		const char *{{s.name}}::type_str() const {
		return "{{s.name}}";
		}

		/**** Properties for {{s.name}} ****/
		{% for f in s.fields %}
		{{f.type_str}} const &{{s.name}}::{{f.name}}() const {
			return _{{f.name}};
		}
		{% if f.is_primitive %}
		void {{s.name}}::set_{{f.name}}({{f.type_str}} const &value) {
			_implicit_start();
			_add_transaction({{f.set_trans_name}}::create(_{{f.name}}));
			_{{f.name}} = value;
			_implicit_end();
		}
		{% else %}
		{{f.type_str}} &{{s.name}}::{{f.name}}() {
			return _{{f.name}};
		}
		{% endif %}
		{% endfor %}
		{% endfor %}
	} /* {{version.namespace_str}} */
	{% endfor %}
}
